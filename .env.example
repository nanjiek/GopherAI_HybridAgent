SERVICE_NAME=gophermind-backend
HTTP_ADDR=:9090

MYSQL_DSN=root:root@tcp(gophermind_mysql:3306)/gophermind?charset=utf8mb4&parseTime=True&loc=Local
REDIS_ADDRS=gophermind_redis:6379
RABBITMQ_URL=amqp://guest:guest@gophermind_rabbitmq:5672/

RABBITMQ_TASK_QUEUE=task_queue
RABBITMQ_RESULT_QUEUE=result_queue
RABBITMQ_RETRY_QUEUE_1=task_queue.retry.1
RABBITMQ_RETRY_QUEUE_2=task_queue.retry.2
RABBITMQ_RETRY_QUEUE_3=task_queue.retry.3
RABBITMQ_DLQ_QUEUE=task_queue.dlq
RABBITMQ_MAX_RETRY=3
RABBITMQ_RETRY_DELAY_1=5s
RABBITMQ_RETRY_DELAY_2=30s
RABBITMQ_RETRY_DELAY_3=120s

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_SECRET_FILE=/run/secrets/jwt_access_secret
JWT_REFRESH_SECRET_FILE=/run/secrets/jwt_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
AUTH_DEV_BYPASS=false

UPLOAD_DIR=./data/uploads
UPLOAD_MAX_FILE_SIZE_BYTES=20971520
UPLOAD_ALLOWED_EXTS=.txt,.md,.pdf,.doc,.docx,.csv,.json,.png,.jpg,.jpeg,.webp

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
BGE_BASE_URL=http://host.docker.internal:8001
BGE_MODEL=bge-reranker-v2-m3

RAG_PYTHON_URL=http://gophermind_rag:8000
QDRANT_API_KEY=
QDRANT_COLLECTION=gophermind_docs
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=cosine
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
BGE_RERANK_MODEL=BAAI/bge-reranker-v2-m3
BGE_USE_FP16=false
CHUNK_SIZE=600
CHUNK_OVERLAP=120
